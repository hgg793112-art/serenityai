# Supabase（從 https://supabase.com/dashboard 專案設定 > API 取得）
VITE_SUPABASE_URL=https://你的專案ID.supabase.co
VITE_SUPABASE_ANON_KEY=你的_anon_公鑰

# Gemini API Key（語音測評功能需要，請至 https://aistudio.google.com/apikey 取得）
# 注意：此 Key 會透過 VITE_ 前綴注入前端，打包後會出現在客戶端 JS 中。
# 正式對外發布前應改為後端代理方式，避免 Key 被提取盜用。
VITE_GEMINI_API_KEY=

# 阿里雲百煉 / DashScope（療癒對話使用千問），請至 https://dashscope.console.aliyun.com/ 取得 API Key
VITE_DASHSCOPE_API_KEY=

# 價格特工：立即搶購按鈕跳轉網址（留空則使用淘寶首頁）
VITE_BUY_BASE_URL=
