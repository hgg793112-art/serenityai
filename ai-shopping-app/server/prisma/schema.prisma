generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  priceSensitivity Float    @default(0.5)
  impulseIndex     Float    @default(0.5)
  categoryWeight   Json     @default("{}")
  events           Event[]
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  type      String
  price     Float?
  category  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id       String  @id @default(uuid())
  name     String
  category String
  price    Float
  brand    String
  rating   Float
}
